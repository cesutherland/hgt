# AppArmor profile permitting bwrap to create unprivileged user namespaces (issue #67).
# Ubuntu 24.04+ restricts unprivileged userns (kernel.apparmor_restrict_unprivileged_userns=1)
# and ships bwrap without setuid, so bwrap can't build its namespace until a profile grants it
# `userns`. Same pattern as the shipped chrome/firefox/crun/buildah profiles. Install once:
#   sudo install -m644 templates/apparmor/bwrap /etc/apparmor.d/bwrap
#   sudo apparmor_parser -r /etc/apparmor.d/bwrap
abi <abi/4.0>,
include <tunables/global>

profile bwrap /usr/bin/bwrap flags=(unconfined) {
  userns,

  # Site-specific additions and overrides.
  include if exists <local/bwrap>
}

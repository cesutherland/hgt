#!/usr/bin/env bash
# hgt test shim — tmux. A dedicated shim (not the generic _shim symlink) because hgt branches
# on `tmux has-session`'s exit code — resume-if-live vs. create-detached, and kill-if-present on
# teardown — so that one subcommand needs an independently controllable result. Everything else
# just gets logged; hgt's contract is *which* tmux commands it issues (pinned via $SHIM_LOG),
# not tmux's effects (asserting those would re-test tmux, not hgt — see ADR 0002/D1).
#
# Records "tmux <args...>" to $SHIM_LOG and honors:
#   has-session: exits per SHIM_TMUX_HAS_SESSION (default 1 = absent, like real tmux;
#                set 0 to simulate a live session for resume/teardown tests)
#   everything else: SHIM_TMUX_OUT / SHIM_TMUX_EXIT, same as _shim
set -euo pipefail
printf 'tmux %s\n' "$*" >>"${SHIM_LOG:?SHIM_LOG not set}"

if [ "${1:-}" = has-session ]; then
  exit "${SHIM_TMUX_HAS_SESSION:-1}"
fi

[ -n "${SHIM_TMUX_OUT:-}" ] && printf '%s\n' "$SHIM_TMUX_OUT"
exit "${SHIM_TMUX_EXIT:-0}"

#!/usr/bin/env bash
# hgt test shim — git. A dedicated shim (not the generic _shim symlink) because hgt's `work`
# path needs git to have done *just enough* for hgt's own filesystem writes to land: after
# `git worktree add ... <path>`, hgt writes the plan file and copies .worktreeinclude files
# INTO <path>, so the path must exist. So this shim fakes exactly one thing — it `mkdir -p`s
# the worktree path on `worktree add` — and nothing else. It is NOT real git: it won't catch
# git-semantic failures (bad --base, path collisions, busted slugs); those aren't hgt's
# contract (which git commands it issues + its own writes), and dogfooding surfaces them.
#
# Records "git <args...>" to $SHIM_LOG and honors the same overrides as _shim:
#   SHIM_GIT_OUT   stdout to emit   (default: none)
#   SHIM_GIT_EXIT  exit code        (default: 0)
set -euo pipefail
printf 'git %s\n' "$*" >>"${SHIM_LOG:?SHIM_LOG not set}"

# `worktree add [<opts>] <path> [<commit-ish>]` — create the path so hgt's writes have a home.
if [ "${1:-}" = worktree ] && [ "${2:-}" = add ]; then
  shift 2
  while [ $# -gt 0 ]; do
    case "$1" in
      -b | -B) shift 2; continue ;;  # branch flag takes a value
      -*) shift; continue ;;          # any other option
      *) mkdir -p "$1"; break ;;      # first positional is the worktree path
    esac
  done
fi

# `-C <wt> rev-parse ... --git-common-dir` — the sandbox seam (#67) asks git for the repo's
# shared .git so it can bind-mount it into the jail. Echo `<wt>/.git` off the `-C` value (a real
# worktree's common dir lives under the main repo, but the exact path isn't hgt's contract — that
# it binds *the resolved common dir* is; a fixed, -C-derived answer keeps the suite hermetic).
if [ "${1:-}" = -C ] && [ "${3:-}" = rev-parse ]; then
  for a in "$@"; do case "$a" in --git-common-dir) printf '%s/.git\n' "$2"; exit 0 ;; esac; done
fi

# `rev-parse ... --git-common-dir` (no -C) — the main-repo resolver behind _worktree_base /
# _repo_slug (#65). SHIM_GIT_COMMON_DIR lets a test stand inside a fake worktree and still get
# the main repo's .git; default $PWD/.git models running from the main checkout.
if [ "${1:-}" = rev-parse ]; then
  for a in "$@"; do
    case "$a" in --git-common-dir) printf '%s\n' "${SHIM_GIT_COMMON_DIR:-$PWD/.git}"; exit 0 ;; esac
  done
fi

# `show-ref --verify --quiet refs/heads/<branch>` — hgt's branch-existence probe that decides
# create (-b) vs. resume (re-attach) when the worktree is absent (issue #23). Answer from
# SHIM_GIT_BRANCH_EXISTS (default absent -> 1 = missing, so today's create path is the default),
# independent of the global SHIM_GIT_EXIT so a test can say "branch exists" without also forcing
# every other git call to that exit code.
if [ "${1:-}" = show-ref ]; then
  exit "${SHIM_GIT_BRANCH_EXISTS:-1}"
fi

[ -n "${SHIM_GIT_OUT:-}" ] && printf '%s\n' "$SHIM_GIT_OUT"
exit "${SHIM_GIT_EXIT:-0}"

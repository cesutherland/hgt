#!/usr/bin/env bash
# hgt test shim — gh. A dedicated shim (not the generic _shim symlink) because hgt's `work` path
# now issues two *different* gh calls that need independently controllable results: the tracker's
# `gh issue view` (the issue record) and the forge's `gh api user` (the branch-author login, issue
# #36). Like git/tmux before it (ADR 0002/D1, 0003), gh graduates so one call's canned output
# doesn't leak into the other. hgt's contract stays "which gh commands it issues," pinned via
# $SHIM_LOG; we don't re-test gh.
#
# Records "gh <args...>" to $SHIM_LOG and honors:
#   api user   -> SHIM_GH_USER   (default: testuser), exits SHIM_GH_USER_EXIT (default: 0) so a
#                                 login-lookup failure can be simulated without failing the
#                                 unrelated `gh issue view` (which shares SHIM_GH_EXIT)
#   everything -> SHIM_GH_OUT
#   exit code  -> SHIM_GH_EXIT   (default: 0)
set -euo pipefail
printf 'gh %s\n' "$*" >>"${SHIM_LOG:?SHIM_LOG not set}"

if [ "${1:-}" = api ] && [ "${2:-}" = user ]; then
  printf '%s\n' "${SHIM_GH_USER:-testuser}"
  exit "${SHIM_GH_USER_EXIT:-0}"
fi

[ -n "${SHIM_GH_OUT:-}" ] && printf '%s\n' "$SHIM_GH_OUT"
exit "${SHIM_GH_EXIT:-0}"
